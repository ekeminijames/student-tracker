# Copy this file to ".env" in apps/web and fill in the real values.
# These come from your Supabase project (Settings -> API) and Sentry.
# The .env file is gitignored and must NEVER be committed.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Supabase "anon" public key (safe to expose in the browser)
VITE_SUPABASE_ANON_KEY=

# Sentry DSN for the frontend (optional until error tracking is wanted)
VITE_SENTRY_DSN=
